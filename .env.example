# Demo mode is enabled by default so local development does not require PostgreSQL.
# Set these to false only when you intentionally want the real API/database flow.
CALO_DEMO_MODE="true"
VITE_DEMO_MODE="true"
EXPO_PUBLIC_DEMO_MODE="true"

# PostgreSQL connection string used by Prisma and the API when CALO_DEMO_MODE=false.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/calo?schema=public"

# API server settings.
PORT=4000
JWT_SECRET="replace-with-a-long-random-secret"
JWT_EXPIRES_IN="7d"
CORS_ORIGIN="http://localhost:5173,http://localhost:5174"
UPLOAD_DIR="uploads"

# Frontend API URLs. Set these in app-specific .env files when needed.
VITE_API_URL="http://localhost:4000/api"
EXPO_PUBLIC_API_URL="http://localhost:4000/api"
